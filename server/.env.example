# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require&channel_binding=require

# JWT & Session Secrets (generate strong random strings)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Google OAuth Callback URLs
# For production (Vercel)
GOOGLE_CALLBACK_URL=https://your-backend.vercel.app/api/auth/google/callback
# For local development (optional, if you want to keep both)
GOOGLE_CALLBACK_URL_LOCAL=http://localhost:3001/api/auth/google/callback

# Frontend & CORS Configuration
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Server Configuration
PORT=3001
NODE_ENV=development

# ============================================
# PRODUCTION EXAMPLE (for Vercel deployment)
# ============================================
# DATABASE_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require&channel_binding=require
# JWT_SECRET=production-secret-key-very-long-and-random
# SESSION_SECRET=production-session-secret-very-long-and-random
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-production-secret
# GOOGLE_CALLBACK_URL=https://your-backend.vercel.app/api/auth/google/callback
# FRONTEND_URL=https://your-frontend-domain.com
# CORS_ORIGIN=https://your-frontend-domain.com
# NODE_ENV=production
